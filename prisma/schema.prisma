// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  images   Image[]
  tagsCreated Tag[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application Models
model Image {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  filepath     String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // EXIF Metadata Fields
  dateTaken     DateTime? // Date/time photo was originally taken
  gpsLatitude   Float?    // GPS latitude coordinate
  gpsLongitude  Float?    // GPS longitude coordinate
  cameraMake    String?   // Camera manufacturer (e.g., "Apple", "Canon")
  cameraModel   String?   // Camera model (e.g., "iPhone 14 Pro")
  fNumber       Float?    // Aperture f-number (e.g., 1.8)
  exposureTime  String?   // Shutter speed (e.g., "1/60")
  iso           Int?      // ISO sensitivity (e.g., 100, 400)
  focalLength   Float?    // Focal length in mm (e.g., 26.0)

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags  ImageTag[]
  faces ImageFace[]
  blob  ImageBlob?

  @@index([userId])
  @@index([createdAt])
  @@index([dateTaken])
  @@index([gpsLatitude, gpsLongitude])
}

model ImageBlob {
  imageId    String   @id
  data       Bytes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  image Image @relation(fields: [imageId], references: [id], onDelete: Cascade)
}

model Tag {
  id              String     @id @default(cuid())
  name            String     @unique
  createdByUserId String?
  images          ImageTag[]
  createdByUser   User?      @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([createdByUserId])
}

model ImageTag {
  imageId String
  tagId   String
  image   Image  @relation(fields: [imageId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([imageId, tagId])
  @@index([imageId])
  @@index([tagId])
}

// Face Detection Models
model Face {
  id             String   @id @default(cuid())
  name           String?  // User-provided label for the person
  faceDescriptor Json     // Face embedding vector used for clustering
  thumbnailPath  String   // Path to cropped face thumbnail image
  imageCount     Int      @default(0) // Cached count of images containing this face
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  images ImageFace[]
  blob   FaceThumbnail?

  @@index([name])
}

model FaceThumbnail {
  faceId      String   @id
  data        Bytes
  mimeType    String   @default("image/jpeg")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  face Face @relation(fields: [faceId], references: [id], onDelete: Cascade)
}

model ImageFace {
  imageId     String
  faceId      String
  boundingBox Json   // {x, y, width, height} coordinates of face in image
  confidence  Float  // Face detection confidence score (0-1)

  image Image @relation(fields: [imageId], references: [id], onDelete: Cascade)
  face  Face  @relation(fields: [faceId], references: [id], onDelete: Cascade)

  @@id([imageId, faceId])
  @@index([imageId])
  @@index([faceId])
}
